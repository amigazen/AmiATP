amiatp.library/AtpProfileGetDisplayName     amiatp.library/AtpProfileGetDisplayName

   NAME
	AtpProfileGetDisplayName -- Profile display name.  (V1)

   SYNOPSIS
	s = AtpProfileGetDisplayName(profile);
	STRPTR AtpProfileGetDisplayName(struct AtpProfile *profile);

   FUNCTION
	Returns the displayName field from getProfile.

   RESULTS
	Library-owned STRPTR until DisposeAtpProfile(), or NULL.
amiatp.library/AtpProfileGetHandle          amiatp.library/AtpProfileGetHandle

   NAME
	AtpProfileGetHandle -- Profile handle.  (V1)

   SYNOPSIS
	s = AtpProfileGetHandle(profile);
	STRPTR AtpProfileGetHandle(struct AtpProfile *profile);

   FUNCTION
	Returns the handle field from getProfile.

   RESULTS
	Library-owned STRPTR until DisposeAtpProfile(), or NULL.
amiatp.library/AtpPutRecord                 amiatp.library/AtpPutRecord

   NAME
	AtpPutRecord -- com.atproto.repo.putRecord.  (V1)

   SYNOPSIS
	err = AtpPutRecord(conn, rec);
	LONG AtpPutRecord(struct AtpConnection *conn, struct AtpRecord *rec);

   FUNCTION
	Creates or replaces a record (collection + rkey required).  Requires
	login.  Updates URI/CID on success.

   RESULTS
	0 on success, else ERROR_ATP_*.

   SEE ALSO
	AtpCreateRecord(), AtpGetRecord()
amiatp.library/AtpRecordGetCid              amiatp.library/AtpRecordGetCid

   NAME
	AtpRecordGetCid -- CID string of a record.  (V1)

   SYNOPSIS
	cid = AtpRecordGetCid(rec);
	STRPTR AtpRecordGetCid(struct AtpRecord *rec);

   FUNCTION
	Returns the CID from the last successful get/create/put.

   RESULTS
	Library-owned STRPTR until DisposeAtpRecord(), or NULL.
amiatp.library/AtpRecordGetString           amiatp.library/AtpRecordGetString

   NAME
	AtpRecordGetString -- Get a top-level string field from record JSON.  (V1)

   SYNOPSIS
	s = AtpRecordGetString(rec, key);
	STRPTR AtpRecordGetString(struct AtpRecord *rec, STRPTR key);

   FUNCTION
	Looks up key in the stored record value JSON and returns a duplicated
	string owned by the record object (valid until DisposeAtpRecord).

   RESULTS
	STRPTR or NULL if missing / not a string.

   NOTES
	Not a general JSON API — shallow string lookup only.
amiatp.library/AtpRecordGetUri              amiatp.library/AtpRecordGetUri

   NAME
	AtpRecordGetUri -- at:// URI of a record.  (V1)

   SYNOPSIS
	uri = AtpRecordGetUri(rec);
	STRPTR AtpRecordGetUri(struct AtpRecord *rec);

   FUNCTION
	Returns the at:// URI from the last successful get/create/put.

   RESULTS
	Library-owned STRPTR until DisposeAtpRecord(), or NULL.
amiatp.library/AtpRecordListGetCount        amiatp.library/AtpRecordListGetCount

   NAME
	AtpRecordListGetCount -- Number of records in a list.  (V1)

   SYNOPSIS
	n = AtpRecordListGetCount(list);
	ULONG AtpRecordListGetCount(struct AtpRecordList *list);

   FUNCTION
	Returns how many records are in the list page.

   RESULTS
	Count, or 0 if invalid.
amiatp.library/AtpRecordListGetRecord       amiatp.library/AtpRecordListGetRecord

   NAME
	AtpRecordListGetRecord -- Nth record in a list.  (V1)

   SYNOPSIS
	rec = AtpRecordListGetRecord(list, index);
	struct AtpRecord *AtpRecordListGetRecord(struct AtpRecordList *list,
	     ULONG index);

   FUNCTION
	Returns a record owned by the list (do not DisposeAtpRecord() it
	separately; DisposeAtpRecordList() frees all).

   RESULTS
	AtpRecord pointer, or NULL if out of range.
amiatp.library/AtpRefreshSession            amiatp.library/AtpRefreshSession

   NAME
	AtpRefreshSession -- Refresh access JWT via refreshJwt.  (V1)

   SYNOPSIS
	err = AtpRefreshSession(conn);
	LONG AtpRefreshSession(struct AtpConnection *conn);

   FUNCTION
	POST com.atproto.server.refreshSession using the stored refreshJwt.
	Updates accessJwt (and related session fields) on success.
	Authed XRPC helpers may call this once on 401 before failing.

   RESULTS
	0 on success, else ERROR_ATP_*.

   SEE ALSO
	AtpLogin(), AtpLogout()
amiatp.library/AtpResolveHandle             amiatp.library/AtpResolveHandle

   NAME
	AtpResolveHandle -- Resolve a handle to a DID.  (V1)

   SYNOPSIS
	err = AtpResolveHandle(conn, handle, did_buf, did_buflen);
	LONG AtpResolveHandle(struct AtpConnection *conn, STRPTR handle,
	     STRPTR did_buf, ULONG did_buflen);

   FUNCTION
	GET com.atproto.identity.resolveHandle.  Writes the DID into did_buf.

   INPUTS
	conn       - AtpConnection (login optional for public resolve).
	handle     - e.g. amigazen.bsky.social
	did_buf    - Output buffer.
	did_buflen - Size including NUL (recommend >= 128).

   RESULTS
	0 on success with NUL-terminated DID in did_buf, else ERROR_ATP_*.
amiatp.library/DisposeAtpConnection         amiatp.library/DisposeAtpConnection

   NAME
	DisposeAtpConnection -- Free an AtpConnection.  (V1)

   SYNOPSIS
	DisposeAtpConnection(conn);
	VOID DisposeAtpConnection(struct AtpConnection *conn);

   FUNCTION
	Logs out locally if needed, disposes the HttpSession, and frees the
	connection.  Safe with NULL.

   SEE ALSO
	NewAtpConnection()
amiatp.library/DisposeAtpFeed               amiatp.library/DisposeAtpFeed

   NAME
	DisposeAtpFeed -- Free a feed and all posts.  (V1)

   SYNOPSIS
	DisposeAtpFeed(feed);
	VOID DisposeAtpFeed(struct AtpFeed *feed);

   FUNCTION
	Frees cursor, post strings (text, URIs, image URLs, avatars), and the
	feed object.  Safe with NULL.  Invalidates all AtpFeedPost pointers
	from this feed.

   SEE ALSO
	AtpGetTimeline(), AtpGetAuthorFeed()
amiatp.library/DisposeAtpProfile            amiatp.library/DisposeAtpProfile

   NAME
	DisposeAtpProfile -- Free a profile object.  (V1)

   SYNOPSIS
	DisposeAtpProfile(profile);
	VOID DisposeAtpProfile(struct AtpProfile *profile);

   FUNCTION
	Frees profile strings and the object.  Safe with NULL.

   SEE ALSO
	AtpGetProfile()
amiatp.library/DisposeAtpRecord             amiatp.library/DisposeAtpRecord

   NAME
	DisposeAtpRecord -- Free a standalone AtpRecord.  (V1)

   SYNOPSIS
	DisposeAtpRecord(rec);
	VOID DisposeAtpRecord(struct AtpRecord *rec);

   FUNCTION
	Frees a record allocated with NewAtpRecord() or not owned by a list.

   NOTES
	Do not call on records owned by an AtpRecordList — dispose the list
	instead.

   SEE ALSO
	NewAtpRecord(), DisposeAtpRecordList()
amiatp.library/DisposeAtpRecordList         amiatp.library/DisposeAtpRecordList

   NAME
	DisposeAtpRecordList -- Free a record list and its records.  (V1)

   SYNOPSIS
	DisposeAtpRecordList(list);
	VOID DisposeAtpRecordList(struct AtpRecordList *list);

   FUNCTION
	Frees the list, cursor, and all contained records.  Safe with NULL.

   SEE ALSO
	AtpListRecords()
amiatp.library/NewAtpConnection             amiatp.library/NewAtpConnection

   NAME
	NewAtpConnection -- Allocate an AT Protocol connection.  (V1)

   SYNOPSIS
	conn = NewAtpConnection();
	struct AtpConnection *NewAtpConnection(void);

   FUNCTION
	Creates an AtpConnection that will own an amihttp HttpSession on first
	XRPC use.  Inherits Tier 0 defaults (service, AppView, CA, UA).
	Configure further with SetAtpConnectionAttrsA() before Login.

   RESULTS
	New connection, or NULL on out of memory.

   SEE ALSO
	DisposeAtpConnection(), SetAtpConnectionAttrsA(), AtpLogin()
amiatp.library/NewAtpRecord                 amiatp.library/NewAtpRecord

   NAME
	NewAtpRecord -- Allocate an empty AtpRecord.  (V1)

   SYNOPSIS
	rec = NewAtpRecord();
	struct AtpRecord *NewAtpRecord(void);

   FUNCTION
	Allocates a record shell for SetAtpRecordAttrsA() / CRUD LVOs.

   RESULTS
	New record, or NULL on out of memory.

   SEE ALSO
	DisposeAtpRecord(), SetAtpRecordAttrsA()
amiatp.library/SetAtpConnectionAttrsA       amiatp.library/SetAtpConnectionAttrsA

   NAME
	SetAtpConnectionAttrsA -- Configure an AtpConnection.  (V1)

   SYNOPSIS
	ok = SetAtpConnectionAttrsA(conn, tags);
	LONG SetAtpConnectionAttrsA(struct AtpConnection *conn,
	     struct TagItem *tags);

   FUNCTION
	Applies ATPA_* tags (see amiatp.library/tags).  Strings are copied.
	Timeouts and CA path are applied to the internal HttpSession when it
	is created or updated.

	Varargs form: SetAtpConnectionAttrs(conn, tag1, val1, ..., TAG_DONE)
	via pragma tagcall.

   INPUTS
	conn - AtpConnection.
	tags - Tag list or NULL (no-op success).

   RESULTS
	Non-zero on success, 0 on invalid handle.

   SEE ALSO
	NewAtpConnection(), amiatp.library/tags
amiatp.library/SetAtpRecordAttrsA           amiatp.library/SetAtpRecordAttrsA

   NAME
	SetAtpRecordAttrsA -- Configure an AtpRecord.  (V1)

   SYNOPSIS
	ok = SetAtpRecordAttrsA(rec, tags);
	LONG SetAtpRecordAttrsA(struct AtpRecord *rec, struct TagItem *tags);

   FUNCTION
	Applies ATPR_* tags (collection, rkey, repo, JSON body, text).
	Varargs form SetAtpRecordAttrs() via pragma tagcall.

   RESULTS
	Non-zero on success, 0 on invalid handle.

   SEE ALSO
	NewAtpRecord(), AtpCreateRecord(), amiatp.library/tags
