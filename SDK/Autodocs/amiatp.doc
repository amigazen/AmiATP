amiatp.library/AtpGetAuthorFeed             amiatp.library/AtpGetAuthorFeed

   NAME
	AtpGetAuthorFeed -- Fetch an actor's feed.  (V1)

   SYNOPSIS
	err = AtpGetAuthorFeed(conn, actor, limit, cursor, &feed);
	LONG AtpGetAuthorFeed(struct AtpConnection *conn, STRPTR actor,
	     ULONG limit, STRPTR cursor, struct AtpFeed **out_feed);

   FUNCTION
	GET app.bsky.feed.getAuthorFeed.  When logged in, uses the PDS with
	Bearer auth; otherwise uses ATPA_APPVIEW without auth.

   INPUTS
	conn     - AtpConnection.
	actor    - Handle or DID (required).
	limit    - Page size; 0 or >50 becomes 20; hard cap 50.
	cursor   - Previous AtpFeedGetCursor(), or NULL for the first page.
	out_feed - Receives allocated feed; caller DisposeAtpFeed().

   RESULTS
	0 on success (*out_feed non-NULL).  Else ERROR_ATP_* (*out_feed NULL).

   SEE ALSO
	AtpGetTimeline(), DisposeAtpFeed()
amiatp.library/AtpGetErrorString            amiatp.library/AtpGetErrorString

   NAME
	AtpGetErrorString -- English string for an ERROR_ATP_* code.  (V1)

   SYNOPSIS
	s = AtpGetErrorString(code);
	STRPTR AtpGetErrorString(LONG code);

   FUNCTION
	Returns a static C string suitable for Printf().  Never NULL for
	known codes; unknown codes return "Unknown amiatp error".

   RESULTS
	Static STRPTR — do not free.

   SEE ALSO
	AtpError(), amiatp.library/errors
amiatp.library/AtpGetProfile                amiatp.library/AtpGetProfile

   NAME
	AtpGetProfile -- Fetch an actor profile.  (V1)

   SYNOPSIS
	err = AtpGetProfile(conn, actor, &profile);
	LONG AtpGetProfile(struct AtpConnection *conn, STRPTR actor,
	     struct AtpProfile **out_profile);

   FUNCTION
	GET app.bsky.actor.getProfile for actor (handle or DID).  Uses PDS
	when logged in, else AppView.

   INPUTS
	conn         - AtpConnection.
	actor        - Handle or DID.
	out_profile  - Receives profile; caller DisposeAtpProfile().

   RESULTS
	0 on success, else ERROR_ATP_*.

   SEE ALSO
	AtpProfileGetHandle(), DisposeAtpProfile()
amiatp.library/AtpGetRecord                 amiatp.library/AtpGetRecord

   NAME
	AtpGetRecord -- com.atproto.repo.getRecord.  (V1)

   SYNOPSIS
	err = AtpGetRecord(conn, rec);
	LONG AtpGetRecord(struct AtpConnection *conn, struct AtpRecord *rec);

   FUNCTION
	Fetches a single record.  Set ATPR_COLLECTION, ATPR_RKEY, and optional
	ATPR_REPO on rec first.  On success, URI/CID/value are stored on rec.

   RESULTS
	0 on success, else ERROR_ATP_*.

   SEE ALSO
	SetAtpRecordAttrsA(), AtpRecordGetString()
amiatp.library/AtpGetTimeline               amiatp.library/AtpGetTimeline

   NAME
	AtpGetTimeline -- Fetch the logged-in user's home timeline.  (V1)

   SYNOPSIS
	err = AtpGetTimeline(conn, limit, cursor, &feed);
	LONG AtpGetTimeline(struct AtpConnection *conn, ULONG limit,
	     STRPTR cursor, struct AtpFeed **out_feed);

   FUNCTION
	GET app.bsky.feed.getTimeline with Bearer auth against ATPA_SERVICE
	(PDS).  Requires login.

	Each feed page parses author handle/displayName/avatar, record text,
	uri, and up to four embed image thumb URLs.

   INPUTS
	conn     - Logged-in AtpConnection.
	limit    - Page size; 0 or >50 becomes 20; hard cap 50.
	cursor   - Previous page cursor, or NULL.
	out_feed - Receives feed; caller must DisposeAtpFeed(*out_feed).

   RESULTS
	0 on success, else ERROR_ATP_* (e.g. ERROR_ATP_NOT_LOGGED_IN,
	ERROR_ATP_AUTH).

   SEE ALSO
	AtpFeedGetCursor(), AtpFeedGetPost(), DisposeAtpFeed()
amiatp.library/AtpListRecords               amiatp.library/AtpListRecords

   NAME
	AtpListRecords -- com.atproto.repo.listRecords.  (V1)

   SYNOPSIS
	err = AtpListRecords(conn, collection, limit, cursor, &list);
	LONG AtpListRecords(struct AtpConnection *conn, STRPTR collection,
	     ULONG limit, STRPTR cursor, struct AtpRecordList **out_list);

   FUNCTION
	Lists records in collection for the session repo (or as configured).
	Requires login.  Cap 50 items per page.

   INPUTS
	conn       - Logged-in connection.
	collection - NSID (e.g. app.bsky.feed.post).
	limit      - Page size (0 → default).
	cursor     - Pagination cursor or NULL.
	out_list   - Receives list; caller DisposeAtpRecordList().

   RESULTS
	0 on success, else ERROR_ATP_*.

   SEE ALSO
	AtpRecordListGetRecord(), DisposeAtpRecordList()
amiatp.library/AtpLogin                     amiatp.library/AtpLogin

   NAME
	AtpLogin -- Create a PDS session (app password).  (V1)

   SYNOPSIS
	err = AtpLogin(conn, identifier, password);
	LONG AtpLogin(struct AtpConnection *conn, STRPTR identifier,
	     STRPTR password);

   FUNCTION
	POST com.atproto.server.createSession against ATPA_SERVICE.
	Stores accessJwt, refreshJwt, did, and handle on the connection.

	Use a Bluesky app password, not the account password.

   INPUTS
	conn       - AtpConnection (configure CA / service first).
	identifier - Handle or email.
	password   - App password.

   RESULTS
	0 on success, else ERROR_ATP_* (often ERROR_ATP_AUTH /
	ERROR_ATP_HTTP_STATUS on bad credentials).

   SEE ALSO
	AtpRefreshSession(), AtpLogout(), AtpConnectionGetDid()
amiatp.library/AtpLogout                    amiatp.library/AtpLogout

   NAME
	AtpLogout -- Clear session JWTs (local).  (V1)

   SYNOPSIS
	err = AtpLogout(conn);
	LONG AtpLogout(struct AtpConnection *conn);

   FUNCTION
	Frees access/refresh JWTs and clears did/handle on the connection.
	Does not require a network round-trip.  Safe if already logged out.

   RESULTS
	0 on success, else ERROR_ATP_INVALID_HANDLE.

   SEE ALSO
	AtpLogin(), DisposeAtpConnection()
